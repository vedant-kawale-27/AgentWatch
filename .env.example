# AgentWatch Environment Configuration Template
# Copy this file to .env and configure the variables for your environment.
# Do not commit the actual .env file containing sensitive values to version control.

# ==============================================================================
# Database Configuration
# ==============================================================================

# Full asyncpg connection string (takes precedence over individual DB_* vars).
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/agentwatch

# Individual database connection parameters (used when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentwatch
DB_USER=postgres

# PostgreSQL user password (required if using individual parameters).
DB_PASSWORD=your_password_here

# Alternative environment variable name for the PostgreSQL password (optional).
PGPASSWORD=your_password_here


# ==============================================================================
# Redis & Celery Configuration
# ==============================================================================

# Connection string for Redis.
REDIS_URL=redis://localhost:6379/0

# Celery broker connection string (falls back to REDIS_URL if not set).
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend connection string (falls back to REDIS_URL if not set).
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ==============================================================================
# API Configuration
# ==============================================================================

# Secret API key required in the 'X-Api-Key' header.
# MANDATORY in production (AGENTWATCH_ENV=production). Unauthenticated if empty in development.
# CLI commands that call the API (status, sessions, export, compare, session
# prune) read this as a fallback for --api-key and send it in the X-Api-Key header.
AGENTWATCH_API_KEY=your_api_key_here

# URL of the AgentWatch API server for CLI/adapters to forward reasoning traces.
AGENTWATCH_API_URL=http://localhost:8000

# Comma-separated allowed CORS origins for the API server.
ALLOWED_ORIGINS=http://localhost:3000

# Alternative environment variable name for comma-separated allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ==============================================================================
# LLM Providers & Auditing (Reasoning Auditor)
# ==============================================================================

# Anthropic API Key used by the Reasoning Auditor to score agent steps and detect drift.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Secret key used for signing/benchmarking reasoning auditor tasks.
AGENTWATCH_BENCH_KEY=default


# ==============================================================================
# Environment Setting
# ==============================================================================

# General application environment mode (e.g., development, production, test).
ENVIRONMENT=development

# AgentWatch specific environment mode (defaults to production if not set).
AGENTWATCH_ENV=development


# ==============================================================================
# Alerting integrations (Optional)
# ==============================================================================

# Slack incoming webhook URL for posting alerts when high-risk commands are blocked.
SLACK_WEBHOOK_URL=

# PagerDuty integration webhook URL for paging when high-risk events occur.
PAGERDUTY_WEBHOOK_URL=

# PagerDuty integration/routing key.
PAGERDUTY_KEY=


# ==============================================================================
# Frontend Configuration (Next.js Dashboard)
# ==============================================================================

# Override host for Next.js to determine API base and WebSocket urls (e.g., localhost:8000).
NEXT_PUBLIC_API_HOST=

# Custom API base path path prefix (defaults to '/api/v1').
NEXT_PUBLIC_API_URL=

# WebSocket URL override for the frontend dashboard live event stream.
NEXT_PUBLIC_WS_URL=
